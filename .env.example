# Hanabi Radar — environment configuration template.
#
# Copy this file to `.env.local` and fill in real values. NEVER commit real
# secrets: `.env.local` (and any `.env*.local`) is gitignored.
#
# - Local dev: get values from your local Supabase stack with
#   `pnpm supabase status`. The local API URL is already provided by default in
#   `.env.development`, so you only need to set the keys here.
# - Deployed (Vercel EU): set these in the Vercel project settings, not here.

# --- Supabase (see FSC-89) ---
# Public — exposed to the browser (NEXT_PUBLIC_*).
# NEXT_PUBLIC_SUPABASE_URL is provided by .env.development for local dev (the
# local API URL); set it in the Vercel project settings for deployed envs. Do
# not set it here — an empty value copied into .env.local would shadow the
# local default and break `pnpm dev`.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only. Bypasses Row Level Security — NEVER expose to the client
# and NEVER commit a real value.
SUPABASE_SERVICE_ROLE_KEY=

# --- Claude API (Anthropic) ---
# Server-only. Used for item classification.
ANTHROPIC_API_KEY=

# --- Classification worker (see FSC-100) ---
# Server-only shared secret authorizing GET/POST /api/classify. The cron scheduler
# sends it as `Authorization: Bearer <secret>`. On Vercel Cron, set this to the
# same value as CRON_SECRET. Use a high-entropy value (e.g. `openssl rand -hex 32`).
CLASSIFY_TRIGGER_SECRET=
