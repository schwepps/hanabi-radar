# Shared, non-secret defaults for local development (loaded by `next dev`,
# not by production builds). Points the app at the local Supabase stack
# (Docker / Supabase CLI) so dev targets local by default.
#
# Secrets (anon / service-role / Claude keys) go in `.env.local` — see
# `.env.example`. Do not put real secrets in this committed file.
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
